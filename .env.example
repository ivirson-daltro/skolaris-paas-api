# Supabase
SUPABASE_URL=https://supa.supabase.co
SUPABASE_KEY=secret_key_example

# Application
NODE_ENV=development
PORT=3000

# JWT configuration
JWT_SECRET=example_jwt_secret_key

# Brevo — use um remetente verificado em https://app.brevo.com/senders (não use domínio não autenticado)
BREVO_API_KEY=example_brevo_api_key
BREVO_SENDER_EMAIL=email-example@email.com  
BREVO_SENDER_NAME=Skolaris App

# Frontend URL for invitation links
FRONTEND_URL=http://localhost:4200
